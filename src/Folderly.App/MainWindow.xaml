<Window x:Class="Folderly.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Folderly.App.Infrastructure"
        Title="{Binding L[MainWindowTitle]}"
        Height="600" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI Variable">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- タブバー -->
            <RowDefinition Height="Auto"/>  <!-- セクションヘッダー -->
            <RowDefinition Height="*"/>     <!-- 履歴リスト -->
            <RowDefinition Height="Auto"/>  <!-- クリアボタン -->
            <RowDefinition Height="Auto"/>  <!-- 試用版バナー -->
        </Grid.RowDefinitions>

        <!-- タブバー -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Background="White">
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                <Button x:Name="HistoryTabBtn" Content="{Binding L[HistoryTab]}"
                        Click="HistoryTab_Click" Padding="16,10" FontSize="14"
                        Foreground="{StaticResource PrimaryBrush}"
                        Background="Transparent" BorderThickness="0,0,0,2"
                        BorderBrush="{StaticResource PrimaryBrush}"/>
                <Button x:Name="SettingsTabBtn" Content="{Binding L[SettingsTab]}"
                        Click="SettingsTab_Click" Padding="16,10" FontSize="14"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Background="Transparent" BorderThickness="0"/>
                <Button Content="{Binding L[HelpTab]}"
                        Click="HelpTab_Click" Padding="16,10" FontSize="14"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Background="Transparent" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- セクションヘッダー -->
        <TextBlock Grid.Row="1" Text="{Binding L[RecentFolders]}"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="20,12,20,8"/>

        <!-- 履歴リスト -->
        <Grid Grid.Row="2">
            <!-- 履歴なし表示 -->
            <TextBlock Text="{Binding L[NoHistory]}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13"
                       Visibility="{Binding HasItems, Converter={x:Static local:BoolToInvisibility.Instance}}"/>

            <!-- 履歴一覧 -->
            <ListView x:Name="HistoryList"
                      ItemsSource="{Binding Items}"
                      BorderThickness="0"
                      Background="Transparent"
                      SelectionMode="Single"
                      Visibility="{Binding HasItems, Converter={x:Static local:BoolToVisibility.Instance}}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="16,10,16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- サムネイル (48x48) -->
                            <Border Grid.Column="0" Width="48" Height="48"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Background="#F0F0F0">
                                <Image Source="{Binding Thumbnail}"
                                       Width="48" Height="48" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <!-- フォルダパス・日時 -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,12,0">
                                <TextBlock Text="{Binding FolderName}"
                                           FontSize="14" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding FolderPath}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,2"/>
                                <TextBlock Text="{Binding AppliedAtText}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <!-- 「開く」ボタン -->
                            <Button Grid.Column="2"
                                    Content="{Binding DataContext.L[OpenFolder], RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource SecondaryButton}"
                                    Tag="{Binding}"
                                    Click="OpenFolder_Click"
                                    Margin="0,0,8,0" Padding="12,5"/>

                            <!-- 「元に戻す」ボタン -->
                            <Button Grid.Column="3"
                                    Content="{Binding DataContext.L[RevertFolder], RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource SecondaryButton}"
                                    Tag="{Binding}"
                                    Click="Revert_Click"
                                    Padding="12,5"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- クリアボタン -->
        <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="16,10">
            <Button Content="{Binding L[ClearAllHistory]}"
                    Style="{StaticResource SecondaryButton}"
                    Click="ClearAllHistory_Click"
                    HorizontalAlignment="Left"/>
        </Border>

        <!-- 試用版バナー -->
        <Border Grid.Row="4"
                Background="#FFF3CD"
                BorderBrush="#FFE69C" BorderThickness="0,1,0,0"
                Padding="16,10"
                Visibility="{Binding ShowTrialBanner, Converter={x:Static local:BoolToVisibility.Instance}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding TrialText}"
                           FontSize="13" VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="{Binding L[BuyNow]}"
                        Style="{StaticResource PrimaryButton}"
                        Click="BuyNow_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
