<UserControl x:Class="Folderly.App.Views.Controls.FolderPreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320" Height="320">
    <!--
        RootCanvas: 320x320 の固定キャンバス。
        - TemplateImage: フォルダ型テンプレート PNG（背景レイヤー）
        - ImageCanvas:   ユーザー画像（ImageRegion に ClipToBounds で切り抜き）
        - TagPath:       タグ色の塗りつぶしパス（フォルダタブ形状に重ねる）
        - FrontTemplateImage: 前面レイヤー（ボトムエッジのみ）
        - Placeholder:   画像未選択時の案内
        座標は FolderPreview.xaml.cs で ImageRegion / TagRegion を 320px にスケールして設定する。
    -->
    <Canvas x:Name="RootCanvas"
            Width="320" Height="320"
            Background="Transparent"
            MouseLeftButtonDown="OnMouseLeftButtonDown"
            MouseMove="OnMouseMove"
            MouseLeftButtonUp="OnMouseLeftButtonUp"
            MouseWheel="OnMouseWheel"
            MouseLeave="OnMouseLeave">

        <Canvas.Effect>
            <DropShadowEffect Color="#000000"
                              BlurRadius="28"
                              ShadowDepth="6"
                              Direction="275"
                              Opacity="0.38"/>
        </Canvas.Effect>

        <!-- フォルダ型テンプレート（背景レイヤー） -->
        <Image x:Name="TemplateImage"
               Width="320" Height="320"
               Stretch="Fill"
               Canvas.Left="0" Canvas.Top="0"
               IsHitTestVisible="False"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- ユーザー画像（ImageRegion 内にクリップ）-->
        <Canvas x:Name="ImageCanvas"
                ClipToBounds="True"
                Background="Transparent"
                IsHitTestVisible="False">
            <Image x:Name="UserImage"
                   Stretch="None"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ImgScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="ImgTranslate" X="0" Y="0"/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
        </Canvas>

        <!-- タグ色オーバーレイ（フォルダタブ形状に重ねる） -->
        <Path x:Name="TagPath"
              IsHitTestVisible="False"
              Visibility="Collapsed"/>

        <!-- 前面レイヤー（ボトムエッジのみ、ポケット廃止） -->
        <Image x:Name="FrontTemplateImage"
               Width="320" Height="320"
               Stretch="Fill"
               Canvas.Left="0" Canvas.Top="0"
               IsHitTestVisible="False"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- 画像未選択時のプレースホルダー -->
        <Border x:Name="Placeholder"
                Width="320" Height="320"
                Canvas.Left="0" Canvas.Top="0"
                IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,28,0,0"
                        Opacity="0.45">
                <TextBlock Text="+"
                           Foreground="#FFFFFF"
                           FontSize="36"
                           FontWeight="Light"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="画像を選択してください"
                           Foreground="#CCDDFF"
                           FontSize="11.5"
                           FontFamily="Yu Gothic UI"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Canvas>
</UserControl>
