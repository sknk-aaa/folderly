<Window x:Class="Folderly.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Folderly.App.Infrastructure"
        Title="{Binding L[SettingsTitle]}"
        Width="440" SizeToContent="Height"
        MinHeight="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI Variable">

    <StackPanel Margin="24,20,24,20">

        <!-- 言語セクション -->
        <TextBlock Text="{Binding L[LanguageSection]}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,8"/>

        <RadioButton Content="{Binding L[LanguageSystem]}"
                     IsChecked="{Binding IsSystemLang}"
                     Margin="0,0,0,4" FontSize="13"/>
        <RadioButton Content="{Binding L[LanguageJapanese]}"
                     IsChecked="{Binding IsJaLang}"
                     Margin="0,0,0,4" FontSize="13"/>
        <RadioButton Content="{Binding L[LanguageEnglish]}"
                     IsChecked="{Binding IsEnLang}"
                     Margin="0,0,0,0" FontSize="13"/>

        <Separator Margin="0,16,0,16" Background="{StaticResource BorderBrush}"/>

        <!-- 履歴セクション -->
        <TextBlock Text="{Binding L[HistorySection]}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding L[HistoryMaxCount]}"
                       FontSize="13" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Width="80"
                     Text="{Binding HistoryMaxCount, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="6,4" TextAlignment="Right"/>
        </Grid>

        <Button Content="{Binding L[DeleteHistory]}"
                Style="{StaticResource SecondaryButton}"
                Click="DeleteHistory_Click"
                HorizontalAlignment="Left"
                FontSize="13" Padding="12,5"/>

        <Separator Margin="0,16,0,16" Background="{StaticResource BorderBrush}"/>

        <!-- Folderly について -->
        <TextBlock Text="{Binding L[AboutSection]}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding L[VersionLabel]}"
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                       Width="90"/>
            <TextBlock Grid.Column="1" Text="{Binding AppVersion}"
                       FontSize="13"/>
        </Grid>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding L[LicenseLabel]}"
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                       Width="90"/>
            <TextBlock Grid.Column="1" Text="{Binding LicenseText}"
                       FontSize="13" TextWrapping="Wrap"/>
        </Grid>

        <StackPanel Orientation="Horizontal">
            <Button Content="{Binding L[SupportLink]}"
                    Style="{StaticResource SecondaryButton}"
                    Click="Support_Click"
                    FontSize="13" Padding="12,5" Margin="0,0,8,0"/>
            <Button Content="{Binding L[LicenseInfo]}"
                    Style="{StaticResource SecondaryButton}"
                    Click="LicenseInfo_Click"
                    FontSize="13" Padding="12,5"/>
        </StackPanel>

        <!-- フッター -->
        <Border BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Margin="-24,20,-24,-20" Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding L[Close]}"
                        Style="{StaticResource PrimaryButton}"
                        Click="Close_Click"
                        Padding="20,7"/>
            </StackPanel>
        </Border>

    </StackPanel>
</Window>
