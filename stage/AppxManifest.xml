<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  IgnorableNamespaces="rescap desktop4 desktop5 com">

  <!--
    Publisher: Store 申請時に Partner Center のパブリッシャー ID（CN=...）に変更すること。
    Version:   リリースごとに 1.0.x.0 形式でインクリメントする。
  -->
  <Identity
    Name="Folderly.FolderlyApp"
    Publisher="CN=Folderly"
    Version="1.0.0.1"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Folderly</DisplayName>
    <PublisherDisplayName>Folderly</PublisherDisplayName>
    <Logo>Images\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily
      Name="Windows.Desktop"
      MinVersion="10.0.17763.0"
      MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application
      Id="App"
      Executable="Folderly.exe"
      EntryPoint="Windows.FullTrustApplication">

      <uap:VisualElements
        DisplayName="Folderly"
        Description="フォルダの見た目を表紙画像と色タグでカスタマイズ"
        BackgroundColor="transparent"
        Square150x150Logo="Images\Square150x150Logo.png"
        Square44x44Logo="Images\Square44x44Logo.png">
        <uap:DefaultTile
          Wide310x150Logo="Images\Wide310x150Logo.png"
          ShortName="Folderly" />
        <uap:SplashScreen Image="Images\SplashScreen.png" />
      </uap:VisualElements>

      <Extensions>

        <!--
          COM SurrogateServer 登録。
          Folderly.ContextMenu.comhost.dll が IExplorerCommand を公開し、Explorer から
          DLL surrogate 経由で読み込まれる。
          Clsid: {2A7A05DA-70D8-4302-8B23-AE8D79D801B6}
        -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:SurrogateServer DisplayName="Folderly Context Menu Handler">
              <com:Class
                Id="2A7A05DA-70D8-4302-8B23-AE8D79D801B6"
                Path="Folderly.ContextMenu.comhost.dll"
                ThreadingModel="STA" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>

        <!--
          フォルダ右クリックメニュー登録（SPEC Section 10.1, F-01）。
          Type="Directory" でフォルダのみに表示される。
          Verb Id は Explorer のメニュー識別子（3〜32文字、英数字のみ）。
        -->
        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
            <desktop5:ItemType Type="Directory">
              <desktop5:Verb
                Id="Folderly"
                Clsid="2A7A05DA-70D8-4302-8B23-AE8D79D801B6" />
            </desktop5:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>

      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <!-- デスクトップアプリとして完全信頼で実行するための制限付きケーパビリティ -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
